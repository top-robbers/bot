# Runtime
NODE_ENV=development
LOG_LEVEL=debug

# Discord
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=
DISCORD_DESCRIPTION=

# Displayed activity once the bot is online
DISCORD_ACTIVITY=Top Robbers

# Internal HTTP server
HTTP_HOST=0.0.0.0
HTTP_PORT=3000

# Internal API protection
# Use a long random value in production. Example: openssl rand -hex 32
INTERNAL_API_SECRET=

# Server (open.mp)
SERVER_IP=127.0.0.1
SERVER_PORT=7777
SERVER_QUERY_INTERVAL_MS=30000