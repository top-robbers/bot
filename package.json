{
    "name": "@top-robbers/bot",
    "version": "0.1.0",
    "description": "Discord bot for Top Robbers.",
    "license": "MIT",
    "type": "module",
    "engines": {
        "node": ">=22.12.0"
    },
    "scripts": {
        "dev": "tsx src/app.ts",
        "build": "tsc -p tsconfig.json",
        "check": "tsc --noEmit -p tsconfig.json",
        "start": "node dist/app.js",
        "commands:deploy": "tsx src/discord/deploy-commands.ts",
        "commands:deploy:prod": "node dist/discord/deploy-commands.js",
        "commands:clear-global": "tsx src/discord/clear-global-commands.ts",
        "commands:clear-global:prod": "node dist/discord/clear-global-commands.js"
    },
    "dependencies": {
        "discord.js": "^14.26.4",
        "dotenv": "^17.4.2",
        "fastify": "^5.8.5",
        "winston": "^3.19.0",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@types/node": "^25.9.1",
        "prettier": "^3.8.3",
        "tsx": "^4.22.3",
        "typescript": "^6.0.3"
    }
}
